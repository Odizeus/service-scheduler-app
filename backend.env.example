# ── Database ─────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=scheduler

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_ME_WITH_RANDOM_HEX
JWT_ALGO=HS256
ACCESS_TOKEN_TTL_MIN=720

# ── Environment ───────────────────────────────────────────────
# Set to "production" to enforce secret + strict CORS validation at startup
APP_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Do not use * in production.
CORS_ORIGINS=http://localhost:3000

# ── Email (Resend) ────────────────────────────────────────────
# Leave blank to run in MOCKED mode (emails stored in DB only)
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# ── Demo Seed ─────────────────────────────────────────────────
SEED_BUSINESS_SLUG=demo-services
SEED_BUSINESS_NAME=Demo Service Co.
SEED_BUSINESS_TIMEZONE=America/New_York
SEED_ADMIN_EMAIL=admin@example.com
# Change before deploying to production!
SEED_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOYMENT

# ── Frontend URL (used for portal links in emails) ────────────
FRONTEND_BASE_URL=http://localhost:3000
